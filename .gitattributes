# Normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly LF for source files
*.py   text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf

# Binary — never touch line endings
*.parquet binary
*.pkl     binary
*.joblib  binary
*.png     binary
*.jpg     binary
