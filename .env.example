# ──────────────────────────────────────────────────────────────────────────────
#  TRADER-AI SYSTEM CONFIGURATION (.env)
# ──────────────────────────────────────────────────────────────────────────────

# --- 1. INFRASTRUCTURE & SECRETS ---
# Primary data feed and execution bridge
TWELVEDATA_API_KEY=
WEBHOOK_URL=http://34.81.61.52/index.php
WEBHOOK_KEY=

# Azure Cloud Persistence
DATA_MODE=CLOUD
CONTAINER_NAME=traderai
AZURE_STORAGE_CONN=
GPU_ENABLED=False

# --- 2. BROKER CREDENTIALS ---
# Required for live streaming data
QUOTEX_EMAIL=
QUOTEX_PASSWORD=
USE_QUOTEX_STREAMING=True

# --- 3. TRADING LOGIC & RISK ---
# Strategy parameters and safety circuit breakers
PAIRS=EUR_USD
OTC_PAIRS=EURUSD_otc
EXPIRY_SECONDS=60
CONFIDENCE_THRESHOLD=0.55
DAILY_TRADE_TARGET=30
DAILY_NET_PROFIT_TARGET=100.0
MARTINGALE_MAX_STREAK=4
MARTINGALE_STEP=0.02
TRADING_WINDOW_HOURS=19
PRACTICE_MODE=True
# Feature Control Switchboard
FEAT_MOMENTUM_ENABLED=True
FEAT_VOLATILITY_ENABLED=True
FEAT_PRICE_ACTION_ENABLED=True
FEAT_MICRO_ENABLED=True
FEAT_CONTEXT_ENABLED=True
# Hard Gates
GATE_MIN_RVOL=1.5
GATE_MAX_SPREAD=0.0005

# --- 4. RESOURCE & ML MANAGEMENT ---
# Hardware guards and data volume limits
MAX_RF_ROWS=1600000
MAX_SEQUENCES=100000
MEMORY_SAVER_MODE=False
TICK_FLUSH_SIZE=500
BACKFILL_YEARS=3
BACKFILL_PAIRS=EUR_USD
POLL_INTERVAL=1.0
TRAIN_ON_FULL_HISTORY=True
MODEL_RETRAIN_INTERVAL=3600
MODEL_SAVE_INTERVAL=1800
# Safety override: set True ONLY if you need to load a model trained
# against an older feature schema. Always retrain and set back to False.
ALLOW_STALE_MODELS=False

# --- 5. REPORTING & MONITORING ---
# Notifications and local dashboard
LOG_LEVEL=INFO
DASHBOARD_PORT=8080
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
