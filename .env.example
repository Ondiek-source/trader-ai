# ──────────────────────────────────────────────────────────────────────────────
#  TRADER-AI SYSTEM CONFIGURATION (.env)
# ──────────────────────────────────────────────────────────────────────────────

# --- 1. INFRASTRUCTURE & SECRETS ---
# Primary data feed and execution bridge
TWELVEDATA_API_KEY=
WEBHOOK_URL=http://34.81.61.52/index.php
WEBHOOK_KEY=

# Azure Cloud Persistence
DATA_MODE=CLOUD
CONTAINER_NAME=traderai
AZURE_STORAGE_CONN=

# --- 2. BROKER CREDENTIALS ---
# Required for live streaming data
QUOTEX_EMAIL=
QUOTEX_PASSWORD=
USE_QUOTEX_STREAMING=True

# --- 3. TRADING LOGIC & RISK ---
# Strategy parameters and safety circuit breakers
PAIRS=EUR_USD
EXPIRY_SECONDS=60
CONFIDENCE_THRESHOLD=0.55
DAILY_TRADE_TARGET=30
DAILY_NET_PROFIT_TARGET=100.0
MARTINGALE_MAX_STREAK=4
TRADING_WINDOW_HOURS=19
PRACTICE_MODE=True

# --- 4. RESOURCE & ML MANAGEMENT ---
# Hardware guards and data volume limits
MAX_RF_ROWS=300000
MAX_SEQUENCES=100000
MEMORY_SAVER_MODE=False
TICK_FLUSH_SIZE=500
BACKFILL_YEARS=2
BACKFILL_PAIRS=EUR_USD
POLL_INTERVAL=1.0

# --- 5. REPORTING & MONITORING ---
# Notifications and local dashboard
LOG_LEVEL=INFO
DASHBOARD_PORT=8501
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

