# ============================================================================
# Trader AI -- Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env with real secrets to version control.
# ============================================================================

# -- Twelve Data (live price feed) -------------------------------------------
TWELVEDATA_API_KEY=your-twelvedata-api-key-here

# -- Azure Blob Storage ------------------------------------------------------
AZURE_STORAGE_CONN=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
CONTAINER_NAME=traderai

# -- Webhook (signal dispatch) -----------------------------------------------
WEBHOOK_URL=https://your-webhook-endpoint.example.com/signal
WEBHOOK_SECRET=your-webhook-hmac-secret

# -- Quotex Credentials ------------------------------------------------------
QUOTEX_EMAIL=your-quotex-email@example.com
QUOTEX_PASSWORD=your-quotex-password

# -- Webhook key (static auth key sent in every signal payload) ---------------
WEBHOOK_KEY=Ondiek

# -- Trading Parameters ------------------------------------------------------
PAIRS=EUR_USD,GBP_USD,USD_JPY,XAU_USD
CONFIDENCE_THRESHOLD=0.65
EXPIRY_SECONDS=60
PRACTICE_MODE=true
DAILY_TRADE_TARGET=10
TARGET_NET_PROFIT=20.0
TRADING_WINDOW_HOURS=19
MARTINGALE_MAX_STREAK=4

# -- Storage Tuning -----------------------------------------------------------
TICK_FLUSH_SIZE=500

# -- Result Callback (trade results POSTed back from your Quotex bot) ---------
RESULT_CALLBACK_PORT=8080

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO

# -- Telegram Bot (commands + session reports) --------------------------------
# Get a token from @BotFather. Leave blank to disable.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# -- Discord Session Reports --------------------------------------------------
# Create an Incoming Webhook in your Discord server. Leave blank to disable.
DISCORD_WEBHOOK_URL=
